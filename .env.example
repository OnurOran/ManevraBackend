# ============================================================
# .env.example — Environment configuration template
#
# Usage:
#   cp .env.example .env
#   Fill in .env with your actual values
#
# .env is listed in .gitignore and must never be committed.
# Share real values with your team through a secure channel
# (e.g. 1Password, Bitwarden, encrypted notes, etc.)
# ============================================================

# ---- Application ----
ASPNETCORE_ENVIRONMENT=Development
API_PORT=8081

# ---- Database (SQL Server) ----
MSSQL_DB=myapp
MSSQL_SA_PASSWORD=            # use a strong password (min 8 chars, upper+lower+digit+symbol)
MSSQL_PORT=1433

# ---- JWT ----
# Minimum 32 characters — generate with:
#   openssl rand -base64 32
JWT_SECRET=                  # paste generated secret here
JWT_ISSUER=MyApp
JWT_AUDIENCE=MyApp
